@inproceedings{FH21_stm,
	author    = {Fukumitsu, Masayuki and Hasegawa, Shingo},
	editor    = {Roman, Rodrigo and Zhou, Jianying},
	booktitle = {The 17th International Workshop on Security and Trust Management (STM2021)},
	title     = {An Aggregate Signature with Pre-Communication in the Plain Public Key Model},
	year      = {2021},
	publisher = {Springer International Publishing},
	address   = {Cham},
	pages     = {3--19},
	month     = {October},
	abstract  = {Aggregate signatures without the bilinear map is a challenging and important problem in aspects of practical and theoretical cryptology. There exists only one aggregate signature which does not use the bilinear map, however, the scheme requires a non-standard cryptographic assumption in the security proof. In ProvSec 2020, Takemure et al. proposed a new variant of aggregate signatures, the aggregate signature with the pre-communication (ASwPC), to realize the security proof from a standard assumption. The ASwPC requires signers to interact with each other to share a temporary randomness before deciding their messages to be signed. After the pre-communication, each signer can start the signing process individually. They gave an instantiation of ASwPC based on the discrete logarithm (DL) assumption, and its security is proven in the random oracle and the knowledge of secret key (KOSK) model.},
	isbn      = {978-3-030-91859-0},
	url       = {https://link.springer.com/chapter/10.1007/978-3-030-91859-0_1},
	comment   = {{"presenter":0}},
	location  = {Darmstadt/Virtual}
}

