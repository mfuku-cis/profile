@incollection{FH16:isc,
	abstract  = {On the security of Fiat-Shamir (FS) type signatures, some negative circumstantial evidences were given in the non-programmable random oracle model (NPROM). Fischlin and Fleischhacker first showed an impossibility for specific FS-type signatures via a single-instance reduction. In ISC 2015, Fukumitsu and Hasegawa found another conditions to prove such an impossibility, however their result requires a strong condition on a reduction, i.e. a key-preserving reduction. In this paper, we focus on a non-key-preserving reduction, and then we show that an FS-type signature cannot be proven to be secure in the NPROM via a sequentially multi-instance reduction from the security of the underlying ID scheme. Our result can be interpreted as a generalization of the two impossibility results introduced above.},
	address   = {Cham},
	author    = {Fukumitsu, Masayuki
	             and Hasegawa, Shingo},
	booktitle = {Information Security},
	comment   = {{"presenter":0}},
	doi       = {10.1007/978-3-319-23318-5_1},
	editor    = {Bishop, Matt
	             and Nascimento, Anderson C A},
	isbn      = {978-3-319-45871-7},
	location  = {Honolulu},
	month     = {September},
	pages     = {389--407},
	publisher = {Springer International Publishing},
	series    = {19th Information Security Conference (ISC2016)},
	title     = {Impossibility on the Provable Security of the {Fiat}-{Shamir}-Type Signatures in the Non-programmable Random Oracle Model},
	volume    = {LNCS 9866},
	year      = {2016}
}

