@inproceedings{FH19,
	author    = {Masayuki Fukumitsu and Shingo Hasegawa},
	title     = {A Tightly-Secure Lattice-Based Multisignature},
	booktitle = {Proceedings of the 6th on ASIA Public-Key Cryptography WorkshopJuly 2019 (APKC'19)},
	year      = {2019},
	pages     = {3--11},
	month     = {July},
	isbn      = {9781450367844},
	publisher = {Association for Computing Machinery},
	address   = {New York, NY, USA},
	url       = {https://doi.org/10.1145/3327958.3329542},
	doi       = {10.1145/3327958.3329542},
	abstract  = {Multisignatures enable multiple users to sign a message in an interactive manner. Many instantiations are proposed for multisignatures, however, most of them are quantum-insecure, because these are based on the integer factoring assumption or the discrete logarithm assumption. Although there exist some constructions based on the lattice problems, which are believed to be quantum-secure, their security reductions are loose. In this paper, we construct a first lattice-based multisignature which has a tight security reduction. Our basic strategy is combining the multisignature scheme proposed by El Bansarkhani and Sturm with the lattice-based standard signature scheme by Abdalla, Fouque, Lyubashevsky and Tibouchi which has a tight security reduction from the Ring-LWE (Ring Learning with Error) assumption.},
	keywords  = {tight security, ring-lwe, multisignature, lattice cryptography},
	comment   = {{"presenter":0}},
	location  = {Auckland},
	owner     = {fukumitsu},
	timestamp = {2019.02.15}
}

