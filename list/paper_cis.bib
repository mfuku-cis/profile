@incollection{FHIKS13:acisp,
	abstract  = {The notion of pseudo-freeness of a group was introduced by Hohenberger, and formalized by Rivest in order to unify cryptographic assumptions. Catalano, Fiore and Warinschi proposed the adaptive pseudo-free group as a generalization of pseudo-free group. They showed that the RSA group {\$}{\backslash}mathbb{\{}Z{\}}{\_}N^{\backslash}times{\$}is pseudo-free even if the adversary against pseudo-freeness is allowed to operate adaptively, provided that the adaptive behavior of the adversary is restricted by some specific parametric distribution. They also proposed the notion of strong adaptive pseudo-freeness in which the adaptive behavior of the adversary is not restricted. However, it remains open whether {\$}{\backslash}mathbb{\{}Z{\}}{\_}N^{\backslash}times{\$}is also strongly-adaptive pseudo-free under the strong RSA (SRSA) assumption.},
	address   = {Berlin, Heidelberg},
	author    = {Fukumitsu, Masayuki
	             and Hasegawa, Shingo
	             and Isobe, Shuji
	             and Koizumi, Eisuke
	             and Shizuya, Hiroki},
	booktitle = {Information Security and Privacy},
	comment   = {{"presenter":0}},
	doi       = {10.1007/978-3-642-39059-3_6},
	editor    = {Boyd, Colin
	             and Simpson, Leonie},
	isbn      = {978-3-642-39059-3},
	location  = {Brisbane},
	month     = {July},
	pages     = {72--87},
	publisher = {Springer Berlin Heidelberg},
	series    = {18th Australasian Conference on Information Security and Privacy (ACISP2013)},
	title     = {Toward Separating the Strong Adaptive Pseudo-freeness from the Strong {RSA} Assumption},
	volume    = {LNCS 7959},
	year      = {2013}
}

@incollection{FHIS14:acisp,
	abstract  = {We pose a question whether or not the standard RSA assumption is sufficient to prove the security of the strong RSA-based (SRSA-based, for short) signatures. In this paper, we show a negative circumstantial evidence for the question. Namely, several SRSA-based signatures cannot be proven to be sEUF-CMA, or even EUF-KOA, under the RSA assumption as far as a modulus-preserving algebraic reduction is concerned. Our result is obtained as an important application of the adaptive pseudo-free group introduced by Catalano, Fiore and Warinschi that can be regarded as an abstract framework of signatures. We in fact show that the adaptive pseudo-freeness of the RSA group {\$}{\backslash}mathbb{\{}Z{\}}{\_}N^{\backslash}times{\$}cannot be proven from the RSA assumption via such reductions.},
	address   = {Cham},
	author    = {Fukumitsu, Masayuki
	             and Hasegawa, Shingo
	             and Isobe, Shuji
	             and Shizuya, Hiroki},
	booktitle = {Information Security and Privacy},
	comment   = {{"presenter":0}},
	doi       = {10.1007/978-3-319-08344-5_19},
	editor    = {Susilo, Willy
	             and Mu, Yi},
	isbn      = {978-3-319-08344-5},
	location  = {Wollongong},
	month     = {July},
	pages     = {290--305},
	publisher = {Springer International Publishing},
	series    = {19th Australasian Conference on Information Security and Privacy (ACISP2014)},
	title     = {On the Impossibility of Proving Security of Strong-{RSA} Signatures via the {RSA} Assumption},
	volume    = {LNCS 8544},
	year      = {2014}
}

